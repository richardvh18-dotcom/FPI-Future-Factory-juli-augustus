{
  "buildCommand": "npm run build && node scripts/update-firestore-version.js || echo 'Version update skipped (FIREBASE_SERVICE_ACCOUNT_JSON not set)'",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/callables/saveQcMeasurement",
      "destination": "https://us-central1-future-factory-377ef.cloudfunctions.net/saveQcMeasurement"
    },
    {
      "source": "/api/callables/saveQcInspection",
      "destination": "https://us-central1-future-factory-377ef.cloudfunctions.net/saveQcInspection"
    },
    {
      "source": "/__/auth/(.*)",
      "destination": "https://future-factory-377ef.firebaseapp.com/__/auth/$1"
    },
    {
      "source": "/__/firebase/(.*)",
      "destination": "https://future-factory-377ef.firebaseapp.com/__/firebase/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/version.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "git": {
    "deploymentEnabled": {
      "pilot-dev": true,
      "FF-2-4-26": false,
      "main": false
    }
  },
  "github": {
    "productionBranch": "pilot-dev"
  }
}
